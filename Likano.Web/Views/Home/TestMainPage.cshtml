@{
    ViewData["Title"] = "LIKANO.GE";
}

<!DOCTYPE html>
<html>
<head>
    <style>
        body {
            margin: 0;
            padding: 0;
            background: linear-gradient(135deg, #1e293b, #0f172a);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: Arial, sans-serif;
        }

        .container {
            text-align: center;
            color: white;
        }

        .logo {
            font-size: 80px;
            font-weight: bold;
            letter-spacing: 8px;
            text-shadow: 0 0 20px rgba(255,255,255,0.3);
        }

        .subtitle {
            margin-top: 15px;
            font-size: 24px;
            color: #cbd5e1;
        }

        .badge {
            margin-top: 30px;
            display: inline-block;
            padding: 12px 25px;
            background-color: #22c55e;
            color: white;
            border-radius: 30px;
            font-weight: bold;
            font-size: 18px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="logo">
            LIKANO.GE
        </div>

        <div class="subtitle">
            Your Online Shopping Destination
        </div>

        <div class="badge">
            🚀 Website is Live
        </div>
    </div>
</body>
</html>