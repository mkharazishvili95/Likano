@{
    Layout = null;
    ViewData["Title"] = "LIKANO.GE - ტექნიკური სამუშაოები";
}

<!DOCTYPE html>
<html lang="ka">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LIKANO.GE</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            font-family: "Segoe UI", Arial, sans-serif;
            background: linear-gradient(135deg, #f8fafc, #e2e8f0);
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .card {
            background: white;
            width: 100%;
            max-width: 850px;
            padding: 60px 40px;
            border-radius: 24px;
            text-align: center;
            box-shadow: 0 20px 50px rgba(0,0,0,0.08);
        }

        .logo {
            font-size: 56px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: 4px;
            margin-bottom: 20px;
        }

        .icon {
            font-size: 72px;
            margin-bottom: 25px;
            animation: pulse 2s infinite;
        }

        .title {
            font-size: 38px;
            color: #1e293b;
            margin-bottom: 20px;
            font-weight: 700;
        }

        .description {
            font-size: 20px;
            color: #64748b;
            line-height: 1.8;
            max-width: 650px;
            margin: 0 auto 35px auto;
        }

        .status {
            display: inline-block;
            padding: 14px 28px;
            border-radius: 50px;
            background: #fef3c7;
            color: #92400e;
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 35px;
        }

        .divider {
            width: 120px;
            height: 4px;
            background: #2563eb;
            border-radius: 10px;
            margin: 0 auto 35px auto;
        }

        .footer {
            color: #94a3b8;
            font-size: 15px;
        }

        @@keyframes pulse {
            0% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.08);
            }

            100% {
                transform: scale(1);
            }
        }

        @@media (max-width: 768px) {
            .card {
                padding: 40px 25px;
            }

            .logo {
                font-size: 40px;
            }

            .title {
                font-size: 28px;
            }

            .description {
                font-size: 17px;
            }
        }
    </style>
</head>
<body>

    <div class="card">

        <div class="logo">
            LIKANO.GE
        </div>

        <div class="icon">
            🛠️
        </div>

        <div class="divider"></div>

        <h1 class="title">
            მიმდინარეობს ტექნიკური სამუშაოები
        </h1>

        <p class="description">
            ბოდიშს გიხდით შეფერხებისთვის.
            <br /><br />

        <div class="status">
            🚧 საიტი დროებით მიუწვდომელია
        </div>

        <div class="footer">
            © @DateTime.Now.Year LIKANO.GE • გმადლობთ მოთმინებისთვის
        </div>

    </div>

</body>
</html>